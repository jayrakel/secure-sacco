@accountNumber = 01148381964600
@userId = BETTERLINK


### ============================================================
### STEP 1 — Generate Fresh Token
### ============================================================
# @name generateToken
POST {{baseUrl}}/token
Authorization: Basic {{basicAuth}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials


### ============================================================
### STEP 2 — Balance Inquiry (Run IMMEDIATELY after Step 1)
### Expected: 200 OK with MessageCode "0"
### This rules out whether the token itself is the issue
### ============================================================
POST {{baseUrl}}/Enquiry/AccountBalance_v2/2.0.0/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "MessageReference": "BVL001TEST01",
  "UserId": "{{userId}}",
  "AccountNumber": "{{accountNumber}}"
}


### ============================================================
### STEP 3 — Balance Inquiry (Run 30 SECONDS after Step 2)
### Same token, different MessageReference
### Expected: Still 200 OK
### If this returns 401 → token is being invalidated mid-session
### ============================================================
POST {{baseUrl}}/Enquiry/AccountBalance_v2/2.0.0/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "MessageReference": "BVL001TEST02",
  "UserId": "{{userId}}",
  "AccountNumber": "{{accountNumber}}"
}


### ============================================================
### STEP 4 — Deposit KES 100, then run this IMMEDIATELY
### Check if AvailableBalance reflects the deposit
### If it does → real-time works in direct API calls
### If it does not → Co-op CBS has posting delay (not our bug)
### ============================================================
POST {{baseUrl}}/Enquiry/AccountBalance_v2/2.0.0/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "MessageReference": "BVL001TEST03",
  "UserId": "{{userId}}",
  "AccountNumber": "{{accountNumber}}"
}


### ============================================================
### STEP 5 — Mini Statement (confirm last 10 transactions)
### Check if the deposit appears here even if balance is stale
### ============================================================
POST {{baseUrl}}/Enquiry/MiniStatement/Account_v2/2.0.0/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "MessageReference": "BVL001TEST04",
  "UserId": "{{userId}}",
  "AccountNumber": "{{accountNumber}}"
}
