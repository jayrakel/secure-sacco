### ============================================================
### BETTERLINK VENTURES SACCO — Production Member Migration
### Environment: prod
### Run: Login first, then run all member requests
### ============================================================

### Step 1 — Login as Admin (MUST RUN FIRST)
POST https://betterlinkventureslimited.co.ke/api/v1/auth/login
Content-Type: application/json

{
  "identifier": "admin@jaytechwavesolutions.co.ke",
  "password": "M1chira._2000"
}

> {%
    const cookies = response.headers.valuesOf("Set-Cookie");
    for (const cookie of cookies) {
        const match = cookie.match(/XSRF-TOKEN=([^;]+)/);
        if (match) {
            client.global.set("csrf_token", decodeURIComponent(match[1]));
            client.log("✅ CSRF token captured: " + decodeURIComponent(match[1]));
        }
    }
    if (response.status === 200) {
        client.log("✅ Login successful");
    } else {
        client.log("❌ Login failed — check credentials");
    }
%}

