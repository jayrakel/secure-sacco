> {%
    const raw = response.headers.valueOf("Set-Cookie");
    if (raw) {
        const match = raw.match(/XSRF-TOKEN=([^;]+)/);
        if (match) client.global.set("csrf_token", match[1]);
        const s = raw.match(/SACCO_SESSION=([^;]+)/);
        if (s) client.global.set("sacco_cookie", "SACCO_SESSION=" + s[1]);
    }
    client.global.set("api_url", "https://staging.jaytechwavesolutions.co.ke");
%}

