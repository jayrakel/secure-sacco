### ============================================================
### MEGA JUMP #1: Fast-Forward to Refinance Date (May 30, 2024)
### 🚨 This simulates 602 days passing. The cron will wake up,
### consume all the prepayments exactly when they were due, and
### apply KES 200 fines for any gaps!
### ============================================================

POST {{baseUrl}}/time-travel/advance?days=602
Cookie: {{sacco_cookie}}
X-XSRF-TOKEN: {{csrf_token}}


### ============================================================
### LOAN 2: REFINANCE (Top-Up KES 300,000) | May 2024 | 21 weeks
### 🚨 ZERO GRACE PERIOD (Punishment applied)
### ============================================================

POST {{baseUrl}}/loans/applications/refinance
Content-Type: application/json
Cookie: {{sacco_cookie}}
X-XSRF-TOKEN: {{csrf_token}}

{
  "oldLoanId": "{{loan1_id}}",
  "loanProductCode": "Historical Smart Loan",
  "topUpAmount": 300000.00,
  "interestOverride": 15000.00,
  "newTermWeeks": 21,
  "referenceNumber": "MIG-BEN-L2-REF",
  "historicalDateOverride": "2024-05-30",
  "firstPaymentDate": "2024-06-06"
}

> {%
    if (response.status === 200) {
        const id = response.body.id || response.body;
        client.global.set("loan2_id", id.toString().trim());
    }
%}

