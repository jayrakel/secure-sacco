### ============================================================
### BENJAMIN MUKETHA — COMPLETE LOAN MIGRATION TEST
### 3 loans: Initial → Refinance (top-up 300K) → Restructure
### ============================================================
@baseUrl = http://localhost:8080/api/v1

### 1. LOGIN & SAVE TOKENS
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "identifier": "jaytechwavesolutions@gmail.com",
  "password": "Michira._2000"
}

> {%
    const cookies = response.headers.valuesOf("Set-Cookie");
    for (const cookie of cookies) {
        const csrf = cookie.match(/XSRF-TOKEN=([^;]+)/);
        if (csrf) client.global.set("csrf_token", csrf[1]);
        const session = cookie.match(/SACCO_SESSION=([^;]+)/);
        if (session) client.global.set("sacco_cookie", "SACCO_SESSION=" + session[1]);
    }
%}

### ============================================================
### 2. INITIALIZE TIME TRAVELER (Start at Oct 6, 2022)
### ============================================================

POST {{baseUrl}}/time-travel/configure
Content-Type: application/json
Cookie: {{sacco_cookie}}
X-XSRF-TOKEN: {{csrf_token}}

{
  "startDate": "2022-10-06",
  "endDate": "2025-08-28",
  "daysPerTick": 7
}

### Reset clock to ensure a clean start
POST {{baseUrl}}/time-travel/reset
Cookie: {{sacco_cookie}}
X-XSRF-TOKEN: {{csrf_token}}

### ============================================================
### LOAN 1: KES 1,000,000 | Oct 2022 | 104 weeks
### 🚨 28-DAY GRACE PERIOD APPLIED HERE
### ============================================================

POST {{baseUrl}}/migration/loans/disburse
Content-Type: application/json
Cookie: {{sacco_cookie}}
X-XSRF-TOKEN: {{csrf_token}}

{
  "memberNumber": "BVL-2022-000001",
  "loanProductCode": "Historical Smart Loan",
  "principal": 1000000.00,
  "interest": 200004.00,
  "weeklyScheduled": 11538.50,
  "firstPaymentDate": "2022-11-03",
  "termWeeks": 104,
  "referenceNumber": "MIG-BEN-L1-DISB"
}

> {%
    if (response.status === 200) {
        const id = response.body.id || response.body;
        client.global.set("loan1_id", id.toString().trim());
    }
%}

