# ─── Database ─────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/sacco_db
DB_USERNAME=sacco_user
DB_PASSWORD=changeme

# ─── Redis (Session Store & Cache) ────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Spring Profile ──────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── Default Admin (Bootstrap) ───────────────────────────────────
APP_DEFAULT_ADMIN_EMAIL=admin@example.com
APP_DEFAULT_ADMIN_PASSWORD=ChangeThisImmediately!
APP_DEFAULT_ADMIN_PHONE=+254700000000
APP_OFFICIAL_EMAIL_DOMAIN=example.com

# ─── CORS ─────────────────────────────────────────────────────────
SACCO_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── M-Pesa / Daraja ─────────────────────────────────────────────
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_BASE_URL=https://your-domain.com

# ─── Encryption & Security ───────────────────────────────────────
APP_FIELD_ENCRYPTION_KEY=your-256-bit-encryption-key-here
APP_PII_HMAC_KEY=your-hmac-key-here

# ─── Backup (Optional — for scripts/backup-db.sh) ────────────────
S3_BUCKET=your-sacco-backups
S3_PREFIX=postgres/daily
SLACK_WEBHOOK_URL=

# ─── Frontend URL (used by backend to build email links) ─────────
# Set this to your production frontend domain in production.
FRONTEND_URL=http://localhost:5173

# ─── Outgoing Email (SMTP / JavaMail) ────────────────────────────
# Compatible with any SMTP relay: SendGrid, AWS SES, Brevo, Gmail, etc.
#
# SendGrid example:
#   MAIL_HOST=smtp.sendgrid.net
#   MAIL_PORT=587
#   MAIL_USERNAME=apikey
#   MAIL_PASSWORD=SG.xxxxxxxxxxxxxxxx
#
# Gmail example (use an App Password, not your account password):
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USERNAME=youraddress@gmail.com
#   MAIL_PASSWORD=your_app_password
#
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yoursacco.co.ke
MAIL_PASSWORD=your_smtp_password_or_api_key
MAIL_FROM=noreply@yoursacco.co.ke

# ─── Frontend (Vite build-time) ──────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080